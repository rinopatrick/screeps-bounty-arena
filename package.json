{
  "name": "screeps-bounty-arena",
  "version": "0.1.0",
  "private": false,
  "description": "Screeps AI bot starter repo with bounty-friendly issues, agent instructions, and PR-ready tasks for automation agents.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "screeps",
    "screeps-ai",
    "screeps-bot",
    "screeps-world",
    "screeps-arena",
    "mmo-ai",
    "programming-game",
    "ai-agent",
    "coding-agent",
    "agent-bounties",
    "bounty",
    "bounties",
    "automation",
    "typescript",
    "javascript",
    "game-ai",
    "colony-ai",
    "creep-ai",
    "pull-requests",
    "simulation",
    "rcl",
    "colony-simulation",
    "agent-prs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "leaderboard:update": "node scripts/update-leaderboard.mjs",
    "simulate": "node scripts/simulate.mjs",
    "simulate:1k": "node scripts/simulate.mjs --ticks 1000 --require-rcl 2 --require-rcl-by 1000 --json",
    "simulate:10k": "node scripts/simulate.mjs --ticks 10000 --require-rcl 4 --require-rcl-by 10000 --json",
    "simulate:gate:rcl2": "node scripts/simulate.mjs --ticks 1000 --require-rcl 2 --require-rcl-by 1000 --markdown",
    "simulate:gate:rcl3": "node scripts/simulate.mjs --ticks 3000 --require-rcl 3 --require-rcl-by 3000 --markdown",
    "deploy:test-server": "node scripts/deploy-test-server.mjs",
    "server:status": "node scripts/test-server-status.mjs",
    "server:proof": "node scripts/local-server-proof.mjs",
    "server:local:up": "docker compose --env-file examples/local-screeps-server/.env -f examples/local-screeps-server/docker-compose.yml up -d",
    "server:local:ps": "docker compose --env-file examples/local-screeps-server/.env -f examples/local-screeps-server/docker-compose.yml ps",
    "server:local:logs": "docker compose --env-file examples/local-screeps-server/.env -f examples/local-screeps-server/docker-compose.yml logs --tail=120 screeps",
    "server:local:cli": "docker compose --env-file examples/local-screeps-server/.env -f examples/local-screeps-server/docker-compose.yml exec screeps screeps-launcher cli",
    "server:local:down": "docker compose --env-file examples/local-screeps-server/.env -f examples/local-screeps-server/docker-compose.yml down",
    "server:local:reset": "docker compose --env-file examples/local-screeps-server/.env -f examples/local-screeps-server/docker-compose.yml down -v"
  },
  "devDependencies": {
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
